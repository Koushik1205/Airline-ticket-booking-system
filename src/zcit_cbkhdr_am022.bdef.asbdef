projection;
strict ( 2 );
use draft;

define behavior for ZCIT_CBKHDR_AM022 alias AirlineBookingHdr
{
  use create;
  use update;
  use delete;
  use action Edit;
  use action Activate;
  use action Discard;
  use action Prepare;
  use action Resume;
  use association _bookingitem { create; with draft; }
}

define behavior for ZCIT_CBKITM_AM022 alias AirlineBookingItm
{
